# QuantX Backend Configuration Example

# Security
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production

# External API Keys (Optional but recommended for full functionality)
OPENAI_API_KEY=sk-...
FMP_API_KEY=...
FRED_API_KEY=...

# Database
DATABASE_URL=sqlite:///./quantx.db

# Deployment
PORT=8000
RENDER_EXTERNAL_URL=https://your-backend-url.render.com
VITE_API_URL=https://your-frontend-url.vercel.app
